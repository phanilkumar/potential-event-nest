# Copy this file to .env and fill in real values — .env is gitignored
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

DATABASE_URL=postgres://<user>:<password>@db:5432/<db_name>
TEST_DATABASE_URL=postgres://<user>:<password>@db:5432/<db_name>_test
DATABASE_HOST=db

DEV_SECRET_KEY_BASE=        # generate: rails secret
TEST_SECRET_KEY_BASE=       # generate: rails secret
